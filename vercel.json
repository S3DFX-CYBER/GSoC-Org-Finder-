{
  "version": 2,
  "framework": null,
  "outputDirectory": ".",
  "buildCommand": "",
  "devCommand": "npx serve . -l $PORT",
  "rewrites": [
    { "source": "/api/github", "destination": "/api/github.js" }
  ],
  "headers": [
      {
      "source": "/data/(.*)\\.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
